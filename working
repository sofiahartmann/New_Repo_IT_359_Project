export async function analyzeLog(logData) {
  const message = logData.message;

  if (message.includes("<script>")) {
    return `
XSS DETECTED 🚨

1. What happened:
A script tag was injected into the input field.

2. Type:
Reflected XSS

3. Why it's dangerous:
It can execute malicious JavaScript in the user's browser.

4. Fix:
- Escape HTML output
- Use innerText instead of innerHTML
- Sanitize input using DOMPurify
`;
  }

  return "No malicious activity detected.";
}
