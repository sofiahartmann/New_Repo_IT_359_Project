1. Improved Monitor Script (Detection)
This version detects both alert() execution and injected <script> tags using a MutationObserver.

(function () {
  function report(data) {
    fetch("/xss-report", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data)
    });
  }

  // Detect alert() execution
  const originalAlert = window.alert;
  window.alert = function (...args) {
    report({ type: "alert_execution", args });
    originalAlert.apply(this, args);
  };

  // Detect script injection via DOM changes
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      mutation.addedNodes.forEach((node) => {
        if (node.tagName === "SCRIPT") {
          report({
            type: "script_injection",
            content: node.innerHTML
          });
        }
      });
    });
  });

  observer.observe(document.documentElement, {
    childList: true,
    subtree: true
  });
})();

2. Updated XSS Classification
function classifyXss(event) {
  if (event.type === "alert_execution") return "reflected_xss";
  if (event.type === "script_injection") return "dom_xss";
  return "unknown_xss";
}

3. Fixing the XSS Vulnerability

Install dependency:
npm install escape-html
Secure the endpoint:
import escapeHtml from "escape-html";

app.post("/comment", (req, res) => {
  const input = req.body.comment;

  const safeInput = escapeHtml(input);

  res.send(`
    <html>
      <body>
        <h2>User comment:</h2>
        ${safeInput}
      </body>
    </html>
  `);
});

4. What This Fix Does
If an attacker submits:
<script>alert("XSS")</script>
It is converted to:
&lt;script&gt;alert("XSS")&lt;/script&gt;
So the browser displays it as text instead of executing it.


